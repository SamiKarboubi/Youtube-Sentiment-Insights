{
    "manifest_version": 3,
    "name": "Youtube Sentiment Insights",
    "version": "1.0",
    "description": "Analyzes YouTube video comments for sentiment.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action":{
        "default_popup":"popup.html",
        "default_icon": "icons/icon128.png",
        "default_title": "YouTube Sentiment"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "tabs",
        "http://localhost/*",
        "https://www.googleapis.com/*"
    ]
}